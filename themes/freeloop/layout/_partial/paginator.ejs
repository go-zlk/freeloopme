<% if (page.total > 1) { %>
<nav class="paginator">
  <% if (page.prev) { %>
    <a href="<%= url_for(page.prev_link) %>">上一页</a>
  <% } %>
  <span class="current"><%= page.current %> / <%= page.total %></span>
  <% if (page.next) { %>
    <a href="<%= url_for(page.next_link) %>">下一页</a>
  <% } %>
</nav>
<% } %>
